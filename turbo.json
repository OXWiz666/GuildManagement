{
  "$schema": "https://turbo.build/schema.json",

  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_ACCESS_EXPIRY",
    "JWT_REFRESH_EXPIRY",
    "SUPABASE_URL",
    "SUPABASE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "BCRYPT_ROUNDS",
    "DISCORD_TOKEN",
    "DISCORD_CLIENT_ID",
    "COMMAND_PREFIX",
    "CP_MAX_VALUE",
    "LINK_CODE_TTL_MINUTES",
    "SPAWN_WARNING_MINUTES",
    "SCHEDULER_INTERVAL_SECONDS",
    "SCHEDULER_ENABLED",
    "CP_REPORT_INTERVAL_HOURS",
    "LOG_LEVEL",
    "FORGEKEEP_ICON_URL",
    "OCR_CACHE_PATH",
    "OCR_MAX_IMAGE_BYTES",
    "OCR_TIMEOUT_MS",
    "OCR_MIN_CONFIDENCE",
    "CP_MAX_GROWTH_RATIO",
    "RATE_LIMIT_COMMANDS_PER_MIN",
    "RATE_LIMIT_SCANS_PER_HOUR"
  ],

  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build", "^db:generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
