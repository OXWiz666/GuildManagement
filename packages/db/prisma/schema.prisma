// ─── Guild Management System — Prisma Schema ────
// Core principle: balances derived from ledger, never stored directly.
// Audit log is append-only. Roles are per-guild.

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // Login identifier alternative to email. Lowercase, unique, immutable-ish
  // (no settings UI to change it yet) — set at registration or auto-generated
  // for OAuth/legacy accounts that never chose one.
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  bannerUrl    String?  @map("banner_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Platform moderation (Super Admin)
  emailVerifiedAt DateTime? @map("email_verified_at")
  bannedAt        DateTime? @map("banned_at")
  suspendedUntil  DateTime? @map("suspended_until")
  deletedAt       DateTime? @map("deleted_at")

  ign    String?
  cp     Int?
  class  String?
  weapon String?

  // Discord identity. Set by redeeming a one-time code (`!link <code>`) minted
  // by the website, so the bot never handles credentials. This link is what
  // lets a Discord message resolve to an actorId for permission checks.
  discordId       String?   @unique @map("discord_id")
  discordUsername String?   @map("discord_username")
  discordLinkedAt DateTime? @map("discord_linked_at")

  // Member-owned payment QR codes (GCash, Maya, etc.) shown to whoever pays
  // them — an array of { id, method, label, qrUrl, updatedAt }.
  paymentMethods Json @default("[]") @map("payment_methods")

  refreshTokens        RefreshToken[]
  sessions             Session[]
  guildMembers         GuildMember[]
  auditLogsAsActor     AuditLog[]            @relation("AuditActor")
  ledgerEntriesAsActor LedgerEntry[]         @relation("LedgerActor")
  passwordResetTokens  PasswordResetToken[]
  guildJoinRequests    GuildJoinRequest[]
  attendanceRecords    AttendanceRecord[]
  factionAnnouncements FactionAnnouncement[] @relation("FactionAnnouncementCreator")
  factionEvents        FactionEvent[]        @relation("FactionEventCreator")
  notifications        Notification[]
  bossRotationsUpdated BossRotation[]        @relation("BossRotationUpdater")
  platformAdmin        PlatformAdmin?
  loginEvents          LoginEvent[]
  foundedFactions      Faction[]             @relation("FactionLeader")
  factionInvitesSent   FactionJoinRequest[]  @relation("FactionJoinRequestInviter")
  discordLinkCodes     DiscordLinkCode[]
  discordServersLinked DiscordServer[]       @relation("DiscordServerLinker")
  discordChannelsSet   DiscordChannel[]      @relation("DiscordChannelSetter")
  cpUpdatesMade        CombatPowerHistory[]  @relation("CpUpdateActor")
  cpHistory            CombatPowerHistory[]  @relation("CpUpdateSubject")
  cpFieldsUpdated      GuildMember[]         @relation("CpUpdatedBy")
  factionAuditLogsAsActor FactionAuditLog[]  @relation("FactionAuditActor")

  @@map("users")
}

// ═══════════════════════════════════════════════════
// LOGIN EVENTS (append-only) — powers login history / device / geo views
// ═══════════════════════════════════════════════════
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") // null = unknown email on a failed attempt
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  success   Boolean  @default(true)
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  country   String?
  device    String?
  browser   String?
  os        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("login_events")
}

// ═══════════════════════════════════════════════════
// PLATFORM ADMINISTRATION (SaaS-level, distinct from per-guild roles)
// A PlatformAdmin grants access to the platform-wide Super Admin area.
// This is NOT the same as the per-guild GuildRole.ADMIN.
// ═══════════════════════════════════════════════════
enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  ANALYST
}

model PlatformAdmin {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        PlatformRole @default(SUPPORT)
  permissions Json         @default("[]") // granular permission overrides / matrix

  // Security (populated in later phases)
  twoFactorSecret String? @map("two_factor_secret")
  backupCodes     Json?   @map("backup_codes")
  ipWhitelist     Json    @default("[]") @map("ip_whitelist")

  lastLoginAt DateTime? @map("last_login_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("platform_admins")
}

// ═══════════════════════════════════════════════════
// AUTHENTICATION
// ═══════════════════════════════════════════════════
model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @map("token_hash") // SHA-256, never raw
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId   String   @map("family_id") // Token family for rotation/replay detection
  isRevoked  Boolean  @default(false) @map("is_revoked")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Session {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  lastActive DateTime @default(now()) @map("last_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([lastActive])
  @@index([userId, lastActive])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════════════════
// FACTIONS
// A faction is a group of guilds led by a Faction Leader.
// Self-serve: created at signup when a user registers as a Faction Leader.
// A guild may optionally belong to one faction (Guild.factionId).
// ═══════════════════════════════════════════════════
model Faction {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  nameChangeCount Int   @default(0) @map("name_change_count")
  description  String?
  avatarUrl    String?  @map("avatar_url")
  // Short display tag, distinct from the URL-style `slug` (e.g. "ABC").
  code         String?  @unique @map("faction_code")
  bannerUrl    String?  @map("banner_url")
  server       String?
  region       String?
  game         String?
  status       FactionStatus @default(ACTIVE)
  leaderUserId String   @map("leader_user_id")
  leader       User     @relation("FactionLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  // Kept in sync with `status` by the service layer (ACTIVE => true, else false)
  // rather than replaced outright, so existing isActive-based reads don't break.
  isActive     Boolean  @default(true) @map("is_active")
  // Redeemable code a Guild Leader uses to request joining this faction (Multi-Guild).
  inviteCode   String   @unique @map("invite_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  guilds             Guild[]
  bossRotations      BossRotation[]
  bossLowRotation    BossLowRotation?
  joinRequests       FactionJoinRequest[]
  guildMemberships   FactionGuildMembership[]
  roleAssignments    FactionRoleAssignment[]
  auditLogs          FactionAuditLog[]
  inventoryItems       FactionInventoryItem[]
  inventoryTransactions FactionInventoryTransaction[]
  inventoryRequests    FactionInventoryRequest[]

  @@index([leaderUserId])
  @@map("factions")
}

enum FactionStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum FactionJoinDirection {
  CODE_REDEEMED
  DIRECT_INVITE
}

enum FactionJoinStatus {
  PENDING
  APPROVED
  REJECTED
}

// A guild joining a faction is two-sided: a code redemption is approved by the
// Faction Leader; a direct invite is approved by the target guild's own leader.
model FactionJoinRequest {
  id                String               @id @default(cuid())
  factionId         String               @map("faction_id")
  faction           Faction              @relation(fields: [factionId], references: [id], onDelete: Cascade)
  guildId           String               @map("guild_id")
  guild             Guild                @relation(fields: [guildId], references: [id], onDelete: Cascade)
  invitedByUserId   String?              @map("invited_by_user_id")
  invitedBy         User?                @relation("FactionJoinRequestInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  direction         FactionJoinDirection
  status            FactionJoinStatus    @default(PENDING)
  respondedByUserId String?              @map("responded_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@index([guildId])
  @@index([factionId, status])
  @@map("faction_join_requests")
}

// Richer faction<->guild relationship record, alongside the fast-path
// `Guild.factionId` FK (which stays the "current faction" pointer used
// everywhere else — boss rotation, market, etc. — untouched). Multiple rows
// per guild are expected over time (LEFT_FACTION / REMOVED history);
// exactly one PENDING/ACTIVE/SUSPENDED row is enforced by the service layer.
model FactionGuildMembership {
  id                      String             @id @default(cuid())
  factionId               String             @map("faction_id")
  faction                 Faction            @relation(fields: [factionId], references: [id], onDelete: Cascade)
  guildId                 String             @map("guild_id")
  guild                   Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  status                  FactionGuildStatus @default(ACTIVE)
  joinedAt                DateTime           @default(now()) @map("joined_at")
  contributionRequirement String?            @map("contribution_requirement")
  // Free-text label, e.g. "Core Guild" — not a permission grant.
  assignedFactionRole     String?            @map("assigned_faction_role")
  approvedByUserId        String?            @map("approved_by_user_id")
  notes                   String?
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  @@index([guildId])
  @@index([factionId, status])
  @@map("faction_guild_memberships")
}

enum FactionGuildStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REMOVED
  LEFT_FACTION
}

// Faction-specific capability grants (Officer / Treasurer / Inventory
// Manager), orthogonal to the GuildRole hierarchy — a member keeps their
// existing guild rank and can additionally hold zero or more of these.
// Faction Leader itself is NOT stored here; it stays derived from
// `Faction.leaderUserId`.
model FactionRoleAssignment {
  id              String          @id @default(cuid())
  factionId       String          @map("faction_id")
  faction         Faction         @relation(fields: [factionId], references: [id], onDelete: Cascade)
  guildMemberId   String          @map("guild_member_id")
  guildMember     GuildMember     @relation(fields: [guildMemberId], references: [id], onDelete: Cascade)
  role            FactionRoleType
  grantedByUserId String          @map("granted_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([guildMemberId, factionId, role])
  @@index([factionId, role])
  @@index([factionId, createdAt])
  @@map("faction_role_assignments")
}

enum FactionRoleType {
  OFFICER
  TREASURER
  INVENTORY_MANAGER
}

// Dedicated append-only faction-scoped audit trail (distinct from the
// existing guild-scoped AuditLog). Never updated or deleted from any service.
model FactionAuditLog {
  id            String   @id @default(cuid())
  factionId     String   @map("faction_id")
  faction       Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  actorId       String   @map("actor_id")
  actor         User     @relation("FactionAuditActor", fields: [actorId], references: [id])
  // Role snapshot at time of action (guild role, not a faction capability role).
  actorRole     String   @map("actor_role")
  action        String
  entityType    String?  @map("entity_type")
  entityId      String?  @map("entity_id")
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  reason        String?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([factionId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
  @@map("faction_audit_logs")
}

// ═══════════════════════════════════════════════════
// FACTIONWIDE SYSTEM — PHASE 2: FACTION INVENTORY
// A centralized item pool shared across a faction's member guilds.
// ═══════════════════════════════════════════════════

model FactionInventoryItem {
  id        String   @id @default(cuid())
  factionId String   @map("faction_id")
  faction   Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  itemName  String   @map("item_name")
  itemIcon  String?  @map("item_icon")
  // Free-text, validated against FACTION_INVENTORY_CATEGORIES in
  // packages/shared/src/constants.ts — same "string, not enum" convention
  // GuildStorageItem.category already uses, so new categories don't need a migration.
  category    String
  rarity      String?
  description String?

  currentQuantity     Int @default(0) @map("current_quantity")
  reservedQuantity     Int @default(0) @map("reserved_quantity")
  distributedQuantity Int @default(0) @map("distributed_quantity")
  // Available = current - reserved, computed at read time (not stored) —
  // storing it risks drift from the two source columns; see service layer.

  unitValueCents    Int?      @map("unit_value_cents") // integer cents — never float, matches GuildStorageItem.listingPrice's convention
  storageLocation   String?   @map("storage_location")
  batchNumber       String?   @map("batch_number")
  expirationDate    DateTime? @map("expiration_date")
  minStockThreshold Int?      @map("min_stock_threshold")
  status            String    @default("ACTIVE") // ACTIVE | ARCHIVED
  createdByUserId   String    @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  transactions FactionInventoryTransaction[]
  requests     FactionInventoryRequest[]

  @@index([factionId, status])
  @@index([factionId, category])
  @@map("faction_inventory_items")
}

enum FactionInventoryTransactionType {
  GUILD_CONTRIBUTION
  MANUAL_ADDITION
  DISTRIBUTION
  RESERVATION
  RESERVATION_RELEASE
  ADJUSTMENT
  REVERSAL
}

enum FactionInventoryApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

// The ledger. previousQuantity/newQuantity are snapshotted at write time
// (not derived later), matching CombatPowerHistory's old_cp/new_cp pattern.
// Never mutated after creation — corrections are new ADJUSTMENT/REVERSAL rows.
model FactionInventoryTransaction {
  id        String               @id @default(cuid())
  factionId String               @map("faction_id")
  faction   Faction              @relation(fields: [factionId], references: [id], onDelete: Cascade)
  itemId    String               @map("item_id")
  item      FactionInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  sourceGuildId      String? @map("source_guild_id")
  destinationGuildId String? @map("destination_guild_id")

  quantity         Int
  previousQuantity Int @map("previous_quantity")
  newQuantity      Int @map("new_quantity")

  transactionType   FactionInventoryTransactionType @map("transaction_type")
  referenceNumber   String?                         @map("reference_number")
  reason            String?
  evidenceUrl       String?                         @map("evidence_url")
  requestedByUserId String                          @map("requested_by_user_id")
  approvedByUserId  String?                         @map("approved_by_user_id")
  approvalStatus    FactionInventoryApprovalStatus  @default(APPROVED) @map("approval_status")
  createdAt         DateTime                        @default(now()) @map("created_at")
  approvedAt        DateTime?                       @map("approved_at")

  @@index([factionId, itemId, createdAt])
  @@index([factionId, approvalStatus])
  @@map("faction_inventory_transactions")
}

enum FactionInventoryRequestPriority {
  NORMAL
  IMPORTANT
  URGENT
  CRITICAL
}

enum FactionInventoryRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISTRIBUTED
  CANCELLED
}

// A guild asking the faction pool for items. Lifecycle: SUBMITTED -> (officer)
// APPROVED (reserves quantity, no stock movement yet) or REJECTED -> officer
// DISTRIBUTED (atomically moves reserved -> distributed, writes a
// FactionInventoryTransaction of type DISTRIBUTION).
model FactionInventoryRequest {
  id                String               @id @default(cuid())
  factionId         String               @map("faction_id")
  faction           Faction              @relation(fields: [factionId], references: [id], onDelete: Cascade)
  itemId            String               @map("item_id")
  item              FactionInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requestingGuildId String               @map("requesting_guild_id")
  requestingGuild   Guild                @relation("FactionInventoryRequestingGuild", fields: [requestingGuildId], references: [id], onDelete: Cascade)
  requestedByUserId String               @map("requested_by_user_id")

  quantity      Int
  purpose       String?
  priority      FactionInventoryRequestPriority @default(NORMAL)
  requiredDate  DateTime?                       @map("required_date")
  evidenceUrl   String?                         @map("evidence_url")
  status        FactionInventoryRequestStatus   @default(SUBMITTED)
  reviewerId    String?                         @map("reviewer_id")
  approvalNotes String?                         @map("approval_notes")
  createdAt     DateTime                        @default(now()) @map("created_at")
  updatedAt     DateTime                        @updatedAt @map("updated_at")

  @@index([factionId, status])
  @@index([requestingGuildId, status])
  @@map("faction_inventory_requests")
}

// ═══════════════════════════════════════════════════
// GUILDS
// ═══════════════════════════════════════════════════
model Guild {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?  @map("avatar_url")
  bannerUrl   String?  @map("banner_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Optional faction this guild belongs to (set when a Faction Leader owns it).
  factionId String?  @map("faction_id")
  faction   Faction? @relation(fields: [factionId], references: [id], onDelete: SetNull)

  // Platform moderation (Super Admin)
  suspendedAt DateTime? @map("suspended_at")
  deletedAt   DateTime? @map("deleted_at")

  inviteCode String? @unique @map("invite_code")
  nameChangeCount Int @default(0) @map("name_change_count")

  settings           GuildSettings?
  members            GuildMember[]
  ledgerEntries      LedgerEntry[]
  auditLogs          AuditLog[]
  joinRequests       GuildJoinRequest[]
  attendanceSessions AttendanceSession[]
  bossSchedules      BossSchedule[]
  bossTurnSchedules  BossSchedule[]             @relation("BossTurnGuild")
  lootSales          LootSale[]
  pointsSnapshots    GuildPointsSnapshot[]
  auctionItems       AuctionItem[]
  itemRequests       ItemRequest[]
  legendaryRequests  LegendaryPriorityRequest[]
  itemDistributions  ItemDistribution[]
  activities         GuildActivity[]
  subscriptions      Subscription[]
  mounts             GuildMount[]
  mountDistributions MountDistribution[]
  factionJoinRequests FactionJoinRequest[]
  roleDefinitions     GuildRoleDefinition[]
  storageItems        GuildStorageItem[]
  bossCommitments     BossCommitment[]
  discordServers      DiscordServer[]
  cpHistory           CombatPowerHistory[]
  cpSnapshots         GuildCpSnapshot[]
  notificationHistory NotificationHistory[]
  factionGuildMemberships FactionGuildMembership[]
  factionInventoryRequests FactionInventoryRequest[] @relation("FactionInventoryRequestingGuild")

  @@index([factionId])
  @@map("guilds")
}

// Guild-defined custom rank names that fully inherit the permissions of one
// of the four customizable GuildRole tiers ("band") — e.g. a "Raid Leader"
// role at band=OFFICER behaves identically to a plain Officer for every
// permission/business-logic check, but displays its own name + color.
model GuildRoleDefinition {
  id        String    @id @default(cuid())
  guildId   String    @map("guild_id")
  guild     Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name      String
  color     String    @default("slate")
  band      GuildRole // app + DB constrained to OFFICER | CORE_MEMBER | ELITE_MEMBER | MEMBER
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  members GuildMember[]

  @@unique([guildId, name])
  @@index([guildId])
  @@map("guild_role_definitions")
}

model GuildSettings {
  id      String @id @default(cuid())
  guildId String @unique @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // General guild metadata used by website scheduling and Discord-facing labels.
  serverName String? @map("server_name")
  timezone   String  @default("Asia/Singapore")
  region     String?
  language   String  @default("en")
  settingsTemplateName String? @map("settings_template_name")

  // Currency config — never hard-coded
  currencyCode            String  @default("PHP") @map("currency_code")
  currencySymbol          String  @default("₱") @map("currency_symbol")
  secondaryCurrencyCode   String? @map("secondary_currency_code") // e.g. "DIAMOND"
  secondaryCurrencySymbol String? @map("secondary_currency_symbol") // e.g. "💎"

  // Economy settings (integer basis points / percentages)
  taxRatePercent Int @default(10) @map("tax_rate_percent")

  // Activity point values (configurable per guild)
  attendancePoints Int @default(10) @map("attendance_points")
  bossKillPoints   Int @default(50) @map("boss_kill_points")

  // Rank multipliers stored as JSON for flexibility
  // e.g. { "GUILD_LEADER": 2.0, "OFFICER": 1.5, "CORE_MEMBER": 1.2, "MEMBER": 1.0 }
  rankMultipliers Json @default("{}") @map("rank_multipliers")

  // Share distribution model
  activeShareModel String @default("EQUAL") @map("active_share_model")

  // Guild Points reset cycle — "MANUAL" | "WEEKLY" | "MONTHLY"
  pointsResetCycle String @default("MANUAL") @map("points_reset_cycle")

  // Per-rank item request limits per cycle (JSON: { "CORE_MEMBER": 7, "ELITE_MEMBER": 7, "MEMBER": 5, "OFFICER": 5 })
  itemRequestLimits Json @default("{}") @map("item_request_limits")

  // Guild Market distribution rules — CP tier thresholds + per-tier item limits + priority weights
  // Shape: { cpTiers: { eliteMinCp, upperMinCp }, limits: { CORE/ELITE/UPPER/LOWER: { logs, temporalPieces, materials } }, weights: {...} }
  marketRules Json @default("{}") @map("market_rules")

  // Per-guild overrides for how OFFICER/CORE_MEMBER/ELITE_MEMBER/MEMBER are displayed.
  // Shape: { OFFICER?: string, CORE_MEMBER?: string, ELITE_MEMBER?: string, MEMBER?: string }
  // Purely cosmetic — never read by permission checks or role hierarchy logic.
  roleDisplayNames Json @default("{}") @map("role_display_names")

  // Leader's Panel "Register Activity" — customizable catalog of point-earning
  // activities (Boss, PVP, Guild Boss, ...) with a base point value and a
  // per-rank multiplier keyed by the 4 customizable role bands.
  // Shape: { activities: [{ key, label, basePoints, multipliers: { OFFICER, CORE_MEMBER, ELITE_MEMBER, MEMBER } }] }
  activityPointRules Json @default("{}") @map("activity_point_rules")

  // Optional catalog of character classes for this guild, used to detect a
  // class from a CP screenshot. `guild_members.class` is free text with no
  // canonical list, so OCR matches against the distinct values already on the
  // roster PLUS this override. Shape: string[] e.g. ["Destroyer", "Hunter"].
  characterClasses Json @default("[]") @map("character_classes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guild_settings")
}

model GuildMember {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  guildId String @map("guild_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  role       GuildRole @default(MEMBER)
  rankName   String    @default("Lower Rank") @map("rank_name")

  // Optional guild-defined custom rank (see GuildRoleDefinition) — when set,
  // `role` above is always kept equal to the definition's `band`.
  customRoleId String?              @map("custom_role_id")
  customRole   GuildRoleDefinition? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  ign        String?   @map("ign") // In-Game Name
  cp         Int?      @map("cp") // Combat Power
  class      String?   @map("class") // Character class (e.g. Warrior, Mage)
  weapon     String?   @map("weapon") // Equipped weapon

  // CP provenance, denormalized onto the row so `!cp` renders "last updated"
  // without touching the history table. CombatPowerHistory stays the append-only
  // record of every change; these two are just the latest entry's who/when.
  cpUpdatedAt   DateTime? @map("cp_updated_at")
  cpUpdatedById String?   @map("cp_updated_by_id")
  cpUpdatedBy   User?     @relation("CpUpdatedBy", fields: [cpUpdatedById], references: [id], onDelete: SetNull)
  memberCode String?   @unique @map("member_code") // Unique member identifier
  joinedAt   DateTime  @default(now()) @map("joined_at")
  isActive   Boolean   @default(true) @map("is_active")

  // Bid points — separate from DKP/ledger balance, earned from same activities
  // Spending on auctions does NOT reduce DKP ranking score
  bidPoints          Int       @default(0) @map("bid_points")
  bidPointsLastReset DateTime? @map("bid_points_last_reset")

  // Guild Market: officer manual priority-sequence override (audited)
  marketPrioritySeq    Int?    @map("market_priority_seq")
  marketPriorityReason String? @map("market_priority_reason")

  // Guild Market: member's chosen/wanted items (array of slot keys) shown to officers
  marketWishlist Json @default("[]") @map("market_wishlist")

  auctionBids        AuctionBid[]
  itemRequests       ItemRequest[]
  legendaryRequests  LegendaryPriorityRequest[]
  itemDistributions  ItemDistribution[]
  equipment          MemberEquipment[]
  mountDistributions MountDistribution[]
  storageReceipts    GuildStorageItem[]         @relation("StorageRecipient")
  bossCommitments    BossCommitment[]
  cpHistory          CombatPowerHistory[]
  factionRoleAssignments FactionRoleAssignment[]

  @@unique([userId, guildId])
  @@index([guildId])
  @@index([guildId, isActive])
  @@index([userId])
  @@index([customRoleId])
  @@index([cpUpdatedById])
  @@map("guild_members")
}

enum GuildRole {
  ADMIN
  FACTION_LEADER
  GUILD_LEADER
  OFFICER
  CORE_MEMBER
  ELITE_MEMBER
  MEMBER
}

// ═══════════════════════════════════════════════════
// GUILD POINTS RESET SNAPSHOTS
// Immutable record of each member's points before each reset
// ═══════════════════════════════════════════════════
model GuildPointsSnapshot {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // Who triggered the reset
  actorId      String   @map("actor_id")
  resetCycle   String   @map("reset_cycle") // "WEEKLY" | "MONTHLY" | "MANUAL"
  snapshotData Json     @map("snapshot_data") // Array of { memberId, userId, ign, dkp, bidPoints }
  membersCount Int      @map("members_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([guildId])
  @@index([createdAt])
  @@map("guild_points_snapshots")
}

// ═══════════════════════════════════════════════════
// AUCTIONS
// Leaders create auction items; members bid with bid points
// ═══════════════════════════════════════════════════
model AuctionItem {
  id        String @id @default(cuid())
  guildId   String @map("guild_id")
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  creatorId String @map("creator_id")

  itemName    String        @map("item_name")
  description String?
  imageUrl    String?       @map("image_url")
  category    String        @default("OTHER") // "WEAPON" | "ARMOR" | etc.
  startingBid Int           @default(0) @map("starting_bid") // in bid points
  currentBid  Int           @default(0) @map("current_bid")
  winnerId    String?       @map("winner_id") // GuildMember.id of winner
  status      AuctionStatus @default(ACTIVE)
  endsAt      DateTime      @map("ends_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  bids AuctionBid[]

  @@index([guildId, status])
  @@index([endsAt])
  @@index([guildId, status, winnerId, endsAt])
  @@map("auction_items")
}

model AuctionBid {
  id        String      @id @default(cuid())
  auctionId String      @map("auction_id")
  auction   AuctionItem @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  memberId  String      @map("member_id")
  member    GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  bidAmount Int         @map("bid_amount") // in bid points
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([auctionId])
  @@index([memberId])
  @@map("auction_bids")
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

// ═══════════════════════════════════════════════════
// ITEM REQUESTS & WITHDRAWAL REQUESTS
// Members request items or currency withdrawals;
// leaders approve/decline/fulfill
// ═══════════════════════════════════════════════════
model ItemRequest {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type   ItemRequestType // ITEM | WITHDRAWAL
  status ItemRequestStatus @default(PENDING)

  // For ITEM requests
  itemName     String? @map("item_name")
  quantity     Int?    @default(1)
  itemCategory String? @map("item_category") // matches CATEGORIES list

  // For WITHDRAWAL requests
  withdrawalAmount   Decimal? @map("withdrawal_amount") @db.Decimal(12, 2)
  withdrawalCurrency String?  @map("withdrawal_currency") // "PHP" | "DIAMOND"

  note         String? // Applicant's note
  reviewNote   String?   @map("review_note") // Leader/officer's response note
  reviewedById String?   @map("reviewed_by_id") // Actor who reviewed
  reviewedAt   DateTime? @map("reviewed_at")
  fulfilledAt  DateTime? @map("fulfilled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@index([memberId])
  @@index([guildId, type, status, updatedAt])
  @@index([guildId, memberId, type, status, updatedAt])
  @@map("item_requests")
}

enum ItemRequestType {
  ITEM
  WITHDRAWAL
}

enum ItemRequestStatus {
  PENDING
  APPROVED
  DECLINED
  FULFILLED
}

// ═══════════════════════════════════════════════════
// GUILD MARKET — LEGENDARY PRIORITY REQUESTS
// Members request priority for legendary-tier rewards;
// officers review, assign a priority sequence, and complete.
// ═══════════════════════════════════════════════════
model LegendaryPriorityRequest {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // WEAPON | LEGEND_ACCESSORIES | LEGEND_CLOAK | ABILITY_REROLL | ABILITY_PASSIVE
  category    String
  currentGear String? @map("current_gear") // Current gear status / context
  reason      String? // Reason for priority
  prioritySeq Int?    @map("priority_seq") // Officer-assigned sequence

  // PENDING | APPROVED | REJECTED | COMPLETED
  status       String    @default("PENDING")
  officerNote  String?   @map("officer_note")
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  completedAt  DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@index([memberId])
  @@map("legendary_priority_requests")
}

// ═══════════════════════════════════════════════════
// GUILD STORAGE — vault of high-value drops (e.g. Clemantis → Legend
// Weapon). While IN_STORAGE, leaders/officers can register the item into
// the next market listing, or distribute it directly to a member
// (GUILD_SALE) or via a DKP auction (GUILD_AUCTION). Purely additive.
// ═══════════════════════════════════════════════════
model GuildStorageItem {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  itemName   String  @map("item_name")
  category   String  @default("LEGEND_WEAPON") // LEGEND_WEAPON | LEGEND_ARMOR | LEGEND_ACCESSORY | MOUNT | OTHER
  sourceBoss String? @map("source_boss") // e.g. "Clemantis"
  rarity     String  @default("LEGEND")
  imageUrl   String? @map("image_url")
  quantity   Int     @default(1)
  note       String?

  // IN_STORAGE | LISTED_MARKET | DISTRIBUTED
  status String @default("IN_STORAGE")
  // How it left storage: MARKET | GUILD_SALE | GUILD_AUCTION | null (still stored)
  disposition String?

  // Asking price (integer cents) set when registered into the next market;
  // cleared back to null on recall. The final sale amount lives on the
  // LootSale row created when the item is marked sold, not here.
  listingPrice BigInt? @map("listing_price")

  // Direct-sale recipient (GUILD_SALE)
  recipientMemberId String?      @map("recipient_member_id")
  recipient         GuildMember? @relation("StorageRecipient", fields: [recipientMemberId], references: [id], onDelete: SetNull)

  // DKP auction created when distributed via GUILD_AUCTION
  auctionItemId String? @map("auction_item_id")

  addedById    String    @map("added_by_id")
  resolvedById String?   @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@map("guild_storage_items")
}

// ═══════════════════════════════════════════════════
// GUILD MARKET — ITEM DISTRIBUTIONS
// Officer-recorded distribution events. Wide per-slot gear
// data is stored as JSON (`items`) for future expansion.
// ═══════════════════════════════════════════════════
model ItemDistribution {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  formType String  @map("form_type") // CORE | NON_CORE
  rankTier String? @map("rank_tier") // CORE | ELITE | UPPER | LOWER

  // Snapshots captured at distribution time (members change over time)
  ignSnapshot    String? @map("ign_snapshot")
  classSnapshot  String? @map("class_snapshot")
  cpSnapshot     Int?    @map("cp_snapshot")
  pointsSnapshot Int?    @map("points_snapshot")
  prioritySeq    Int?    @map("priority_seq")

  // { weapon: 1, headpiece: 1, logs: 5, temporalPieces: 3, materials: 2, ... }
  items Json    @default("{}")
  note  String?

  distributedById String   @map("distributed_by_id")
  overridden      Boolean  @default(false) // Rank limit override used
  overrideReason  String?  @map("override_reason")
  distributedAt   DateTime @default(now()) @map("distributed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([guildId, distributedAt])
  @@index([memberId])
  @@map("item_distributions")
}

// ═══════════════════════════════════════════════════
// MOUNT WISHLIST — leader-defined catalog of available
// mounts with a max number of distribution slots each.
// Members wish for mounts; distributing one consumes a slot.
// ═══════════════════════════════════════════════════
model GuildMount {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  name     String
  iconUrl  String? @map("icon_url")
  maxSlots Int     @default(1) @map("max_slots")
  isActive Boolean @default(true) @map("is_active")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  distributions MountDistribution[]

  @@index([guildId])
  @@map("guild_mounts")
}

model MountDistribution {
  id      String     @id @default(cuid())
  guildId String     @map("guild_id")
  guild   Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  mountId String     @map("mount_id")
  mount   GuildMount @relation(fields: [mountId], references: [id], onDelete: Cascade)

  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  ignSnapshot     String?  @map("ign_snapshot")
  mountNameSnapshot String? @map("mount_name_snapshot")
  note            String?
  distributedById String   @map("distributed_by_id")
  distributedAt   DateTime @default(now()) @map("distributed_at")

  @@index([guildId, distributedAt])
  @@index([mountId])
  @@index([memberId])
  @@map("mount_distributions")
}

// ═══════════════════════════════════════════════════
// MEMBER EQUIPMENT — Item Screenshot Update feature
// Per-slot gear detected from an uploaded equipment screenshot
// (OCR in the browser) and matched to existing Supabase icon objects.
// One current item per slot (upsert on re-scan). We only ever REFERENCE
// existing icon storage paths here — never write to the icon buckets.
// ═══════════════════════════════════════════════════
model MemberEquipment {
  id       String      @id @default(cuid())
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  slotType String @map("slot_type") // one of EQUIPMENT_SLOTS keys (weapon, helm, ...)
  itemName String @map("item_name")

  // Storage PATH (bucket-relative object key), signed on read — never a raw public URL
  iconUrl    String @map("icon_url")
  iconBucket String @map("icon_bucket")
  rarity     String?

  confidence  Float   @default(0)
  needsReview Boolean @default(false) @map("needs_review")

  // Storage path of the uploaded source screenshot (EquipmentScreenshots bucket)
  sourceScreenshotUrl String? @map("source_screenshot_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([memberId, slotType])
  @@index([memberId])
  @@map("member_equipment")
}

// ═══════════════════════════════════════════════════
// IMMUTABLE LEDGER
// Balances are ALWAYS derived by summing entries.
// Entries are NEVER updated or deleted.
// ═══════════════════════════════════════════════════
model LedgerEntry {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  // Who is affected
  accountType AccountType @map("account_type")
  accountId   String      @map("account_id") // userId or guildId

  // What changed — integer units (cents), never float
  currency  String
  amount    BigInt // Stored as integer cents/smallest unit
  entryType LedgerEntryType @map("entry_type")

  // Why — links to the source event
  referenceType String @map("reference_type") // "BOSS_KILL", "SALE", "PAYOUT", etc.
  referenceId   String @map("reference_id")

  // Idempotency — prevents double-crediting on retries
  idempotencyKey String @unique @map("idempotency_key")

  // Who initiated it
  actorId String @map("actor_id")
  actor   User   @relation("LedgerActor", fields: [actorId], references: [id])

  description String?
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([accountType, accountId, currency])
  @@index([guildId])
  @@index([guildId, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([guildId, accountType, entryType, currency])
  @@index([guildId, accountType, currency, createdAt])
  @@index([guildId, accountId, accountType, referenceType])
  @@index([guildId, accountId, accountType, entryType, currency])
  @@map("ledger_entries")
}

enum AccountType {
  MEMBER
  GUILD_FUND
  TAX
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

// ═══════════════════════════════════════════════════
// AUDIT LOG — append-only, every significant action
// ═══════════════════════════════════════════════════
model AuditLog {
  id String @id @default(cuid())

  // Who performed the action
  actorId String @map("actor_id")
  actor   User   @relation("AuditActor", fields: [actorId], references: [id])

  // Where (optional — some actions are system-wide)
  guildId String? @map("guild_id")
  guild   Guild?  @relation(fields: [guildId], references: [id])

  // What happened
  action   String // "USER_LOGIN", "MEMBER_PROMOTED", etc.
  target   String? // Target entity type
  targetId String? @map("target_id")

  // Details — before/after state, extra context
  detail    Json?
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([guildId])
  @@index([action])
  @@index([createdAt])
  @@index([guildId, action, createdAt])
  @@map("audit_logs")
}

model FactionAnnouncement {
  id        String   @id @default(cuid())
  title     String
  body      String
  priority  String   @default("NORMAL")
  status    String   @default("ACTIVE")
  creatorId String   @map("creator_id")
  creator   User     @relation("FactionAnnouncementCreator", fields: [creatorId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("faction_announcements")
}

model FactionEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  location    String?
  status      String    @default("ACTIVE")
  creatorId   String    @map("creator_id")
  creator     User      @relation("FactionEventCreator", fields: [creatorId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([startsAt])
  @@map("faction_events")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  metadata  Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model GuildJoinRequest {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  userId  String @map("user_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ign       String            @map("ign")
  cp        Int               @map("cp")
  class     String            @map("class")
  weapon    String            @map("weapon")
  status    JoinRequestStatus @default(PENDING)

  // Equipment captured at apply time (Item Screenshot Update). Array of
  // { slotType, itemName, iconPath, iconBucket, rarity?, confidence }. Shown to
  // the reviewing leader and materialised into MemberEquipment on acceptance.
  gearItems Json? @map("gear_items")

  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([userId, guildId])
  @@index([guildId])
  @@index([userId])
  @@index([userId, status])
  @@index([guildId, status, createdAt])
  @@map("guild_join_requests")
}

enum AttendanceType {
  GUILD
  FACTION
}

enum AttendanceRecordStatus {
  PENDING
  CONFIRMED
}

enum BossEventStatus {
  UPCOMING
  SPAWNED
  KILLED
}

model AttendanceSession {
  id             String             @id @default(cuid())
  guildId        String             @map("guild_id")
  guild          Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  code           String             @unique
  type           AttendanceType     @default(GUILD)
  title          String
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")
  expiresAt      DateTime           @map("expires_at")
  records        AttendanceRecord[]
  bossScheduleId String?            @map("boss_schedule_id")
  bossSchedule   BossSchedule?      @relation(fields: [bossScheduleId], references: [id], onDelete: SetNull)

  @@index([guildId])
  @@index([guildId, createdAt])
  @@index([guildId, expiresAt])
  @@index([bossScheduleId])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String                 @id @default(cuid())
  sessionId String                 @map("session_id")
  userId    String                 @map("user_id")
  session   AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    AttendanceRecordStatus @default(PENDING)
  joinedAt  DateTime               @default(now()) @map("joined_at")

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@index([userId])
  // Officer "pending verification" queue filters by session + status.
  @@index([sessionId, status])
  @@map("attendance_records")
}

model BossSchedule {
  id                 String              @id @default(cuid())
  guildId            String?             @map("guild_id") // Null means Faction unified schedule
  guild              Guild?              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  bossName           String              @map("boss_name")
  bossImageUrl       String?             @map("boss_image_url")
  spawnTime          DateTime            @map("spawn_time")
  location           String
  guildTurn          String?             @map("guild_turn")
  guildTurnGuildId   String?             @map("guild_turn_guild_id")
  guildTurnGuild     Guild?              @relation("BossTurnGuild", fields: [guildTurnGuildId], references: [id], onDelete: SetNull)
  status             BossEventStatus     @default(UPCOMING)
  killedAt           DateTime?           @map("killed_at")
  creatorId          String              @map("creator_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  attendanceSessions AttendanceSession[]

  lootDrop      String?    @map("loot_drop")
  screenshotUrl String?    @map("screenshot_url")
  lootSales     LootSale[]
  commitments   BossCommitment[]

  @@index([guildId])
  @@index([guildTurnGuildId])
  @@index([spawnTime])
  @@index([status])
  @@index([guildId, status, killedAt])
  @@index([bossName, status, spawnTime])
  @@index([bossName, status, killedAt])
  @@map("boss_schedules")
}

// ═══════════════════════════════════════════════════
// BOSS COMMITMENTS — pre-fight headcount. A member marks themselves as able
// to participate in a SPECIFIC upcoming spawn (one row per live BossSchedule),
// so leaders can gauge war-readiness turnout before the boss is even taken.
// Distinct from AttendanceRecord, which confirms who actually showed up
// AFTER a kill is logged.
// ═══════════════════════════════════════════════════
model BossCommitment {
  id         String      @id @default(cuid())
  guildId    String      @map("guild_id")
  guild      Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  scheduleId String      @map("schedule_id")
  schedule   BossSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  memberId   String      @map("member_id")
  member     GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@unique([scheduleId, memberId])
  @@index([guildId, scheduleId])
  @@map("boss_commitments")
}

model BossRotation {
  id            String    @id @default(cuid())
  factionId     String    @map("faction_id")
  faction       Faction   @relation(fields: [factionId], references: [id], onDelete: Cascade)
  bossName      String    @map("boss_name")
  queueGuildIds Json      @map("queue_guild_ids")
  currentIndex  Int       @default(0) @map("current_index")
  nextSpawnTime DateTime? @map("next_spawn_time")
  // When true, queueGuildIds is the faction leader's explicit master-list of
  // participating guilds for this boss and is honored as-is (guilds NOT listed
  // are excluded). When false, the queue defaults to all active faction guilds.
  participantsConfigured Boolean @default(false) @map("participants_configured")
  updatedById   String?   @map("updated_by_id")
  updatedBy     User?     @relation("BossRotationUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([factionId, bossName])
  @@index([factionId])
  @@map("boss_rotations")
}

/**
 * Day-based low-boss rotation (faction-leader owned). A single-row config for the
 * faction: the guild assigned to a day takes ALL flagged "low" bosses that day.
 *  - mode:         WEEKLY (weekday→guild, repeats) or MONTHLY (calendar date→guild)
 *  - lowBossNames: which registry bosses follow this day rotation (JSON string[])
 *  - weekly:       { "0".."6" (Sun..Sat) → guildId } (JSON)
 *  - days:         { "YYYY-MM-DD" → guildId } (JSON)
 */
model BossLowRotation {
  factionId    String   @id @map("faction_id")
  faction      Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  mode         String   @default("MONTHLY")
  lowBossNames Json     @default("[]") @map("low_boss_names")
  weekly       Json     @default("{}")
  days         Json     @default("{}")
  updatedById  String?  @map("updated_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("boss_low_rotations")
}

/**
 * Unified guild activity scheduler: Guild Boss, Guild War, and PK War events.
 * A simple calendar entry with optional opponent, result, and member attendance.
 */
model GuildActivity {
  id             String                  @id @default(cuid())
  guildId        String                  @map("guild_id")
  guild          Guild                   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type           String // GUILD_BOSS | GUILD_WAR | PK_WAR
  title          String
  location       String?
  opponent       String? // enemy / rival guild
  notes          String?
  scheduledAt    DateTime                @map("scheduled_at")
  status         String                  @default("UPCOMING") // UPCOMING | COMPLETED | CANCELLED
  result         String? // WIN | LOSS | DRAW
  scoreFor       Int?                    @map("score_for")
  scoreAgainst   Int?                    @map("score_against")
  // When set (WEEKLY | BIWEEKLY | MONTHLY), completing this activity
  // auto-creates the next occurrence offset by the interval, carrying the
  // same interval forward so it keeps repeating like a recurring alarm.
  repeatInterval String?                 @map("repeat_interval")
  creatorId      String                  @map("creator_id")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  attendees      GuildActivityAttendee[]

  @@index([guildId, scheduledAt])
  @@index([guildId, type, status])
  @@map("guild_activities")
}

model GuildActivityAttendee {
  id         String        @id @default(cuid())
  activityId String        @map("activity_id")
  activity   GuildActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String        @map("user_id")
  status     String        @default("PENDING") // PENDING | CONFIRMED
  joinedAt   DateTime      @default(now()) @map("joined_at")

  @@unique([activityId, userId])
  @@index([activityId])
  @@map("guild_activity_attendees")
}

model Boss {
  id            String   @id @default(cuid())
  name          String   @unique
  level         Int
  type          String // "LONG_CYCLE" | "FIXED_SCHEDULE"
  cooldownHours Int?     @map("cooldown_hours")
  location      String
  fixedSpawns   Json?    @map("fixed_spawns")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("bosses")
}

model LootSale {
  id                String        @id @default(cuid())
  guildId           String        @map("guild_id")
  guild             Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  bossScheduleId    String?       @map("boss_schedule_id")
  bossSchedule      BossSchedule? @relation(fields: [bossScheduleId], references: [id], onDelete: SetNull)
  itemName          String        @map("item_name")
  category          String // e.g. "WEAPON", "ARMOR", "ACCESSORY", "MATERIAL", "SCROLL", "OTHER"
  saleValue         BigInt        @map("sale_value") // Integer cents
  taxRatePercent    Int           @map("tax_rate_percent")
  taxAmount         BigInt        @map("tax_amount") // Integer cents
  netProfit         BigInt        @map("net_profit") // Integer cents
  distributionModel String        @map("distribution_model") // "PRO_RATA", "EQUAL", "DKP"
  currency          String        @default("PHP")
  creatorId         String        @map("creator_id")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([guildId])
  @@index([bossScheduleId])
  // Sold-item log is read newest-first per guild.
  @@index([guildId, createdAt])
  @@map("loot_sales")
}

// ═══════════════════════════════════════════════════
// BILLING (SaaS platform) — subscriptions, payments, invoices, coupons.
// Money is stored as integer minor units (e.g. centavos), like the ledger.
// ═══════════════════════════════════════════════════
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CHARGEBACK
}

enum PaymentGatewayType {
  STRIPE
  PAYMONGO
  XENDIT
  PAYPAL
  GCASH
  MAYA
  MANUAL
}

enum CouponType {
  PERCENT
  FIXED
  FREE_TRIAL
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

model SubscriptionPlan {
  id           String  @id @default(cuid())
  name         String
  description  String?
  monthlyPrice Int     @map("monthly_price") // minor units
  yearlyPrice  Int     @map("yearly_price")
  currency     String  @default("PHP")
  limits       Json    @default("{}") // maxGuildMembers, maxStorage, maxBossSchedules, maxApiRequests, ocr, aiCredits...
  features     Json    @default("{}") // marketplaceAccess, analyticsAccess, prioritySupport, customBranding, discord, webhooks (booleans)
  isActive     Boolean @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  planId  String @map("plan_id")
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  status           SubscriptionStatus @default(TRIALING)
  interval         BillingInterval    @default(MONTHLY)
  currentPeriodEnd DateTime?          @map("current_period_end")
  cancelAt         DateTime?          @map("cancel_at")
  gateway          PaymentGatewayType @default(MANUAL)
  externalId       String?            @map("external_id")
  couponId         String?            @map("coupon_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments Payment[]
  invoices Invoice[]

  @@index([guildId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id             String  @id @default(cuid())
  subscriptionId String? @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  guildId        String  @map("guild_id")

  amount         Int // minor units
  currency       String             @default("PHP")
  status         PaymentStatus      @default(PENDING)
  gateway        PaymentGatewayType
  externalId     String?            @map("external_id")
  failureReason  String?            @map("failure_reason")
  refundedAmount Int                @default(0) @map("refunded_amount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events  PaymentEvent[]
  invoice Invoice?

  @@index([guildId])
  @@index([status])
  @@map("payments")
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String   @map("payment_id")
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type      String // "created" | "succeeded" | "failed" | "refunded" | "chargeback" ...
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@map("payment_events")
}

model Invoice {
  id             String  @id @default(cuid())
  number         String  @unique
  subscriptionId String? @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentId      String? @unique @map("payment_id")
  payment        Payment? @relation(fields: [paymentId], references: [id])
  guildId        String  @map("guild_id")

  subtotal  Int
  taxAmount Int    @default(0) @map("tax_amount")
  total     Int
  currency  String @default("PHP")
  status    String @default("DRAFT") // DRAFT | ISSUED | PAID | VOID
  pdfUrl    String? @map("pdf_url")
  issuedAt  DateTime? @map("issued_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId])
  @@map("invoices")
}

model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  type         CouponType
  amount       Int // percent (0-100) or fixed minor units
  currency     String?
  maxUses      Int?      @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  expiresAt    DateTime? @map("expires_at")
  restrictions Json      @default("{}")
  isActive     Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("coupons")
}

// ═══════════════════════════════════════════════════
// DISCORD BOT
// The bot shares this database with the website — it never owns a second copy
// of guild/boss/member state. Boss kills and spawns live in BossSchedule;
// members live in GuildMember. Only Discord-specific concepts are modeled here.
// ═══════════════════════════════════════════════════

/**
 * One-time code minted by the website and redeemed in Discord via `!link`.
 * Short TTL + single use: `consumedAt` is set in the same transaction that
 * writes User.discordId, so a leaked code can't be replayed.
 */
model DiscordLinkCode {
  code                String    @id
  userId              String    @map("user_id")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime  @map("expires_at")
  consumedAt          DateTime? @map("consumed_at")
  consumedByDiscordId String?   @map("consumed_by_discord_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("discord_link_codes")
}

/**
 * Binds a Discord server to a ForgeKeep guild. Every command resolves its
 * tenant through this row — an unbound Discord server can read nothing.
 */
model DiscordServer {
  id             String   @id @default(cuid())
  discordGuildId String   @unique @map("discord_guild_id")
  guildId        String   @map("guild_id")
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // IANA zone for interpreting bare `!kill <boss> HH:MM` wall-clock times.
  timezone       String   @default("Asia/Singapore")
  pingRoleId     String?  @map("ping_role_id")
  isActive       Boolean  @default(true) @map("is_active")
  linkedById     String?  @map("linked_by_id")
  linkedBy       User?    @relation("DiscordServerLinker", fields: [linkedById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  channels            DiscordChannel[]
  aliases             DiscordAlias[]
  notificationHistory NotificationHistory[]

  @@index([guildId])
  @@map("discord_servers")
}

/** !notifhere / !cmdhere / !threadhere targets — one channel per purpose. */
model DiscordChannel {
  id              String        @id @default(cuid())
  discordServerId String        @map("discord_server_id")
  discordServer   DiscordServer @relation(fields: [discordServerId], references: [id], onDelete: Cascade)
  purpose         String // NOTIFICATION | COMMAND | THREAD
  channelId       String        @map("channel_id")
  setById         String?       @map("set_by_id")
  setBy           User?         @relation("DiscordChannelSetter", fields: [setById], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([discordServerId, purpose])
  @@map("discord_channels")
}

/**
 * Boss nickname → registry name (e.g. "baron" → "Baron Baraudmore").
 * A null discordServerId is a global alias; a server-scoped row overrides it.
 * Uniqueness is enforced by two partial indexes in SQL (see migration 0019) —
 * NULL != NULL would let a plain compound unique admit duplicate globals.
 */
model DiscordAlias {
  id              String         @id @default(cuid())
  discordServerId String?        @map("discord_server_id")
  discordServer   DiscordServer? @relation(fields: [discordServerId], references: [id], onDelete: Cascade)
  alias           String // stored lowercase
  bossName        String         @map("boss_name")
  createdById     String?        @map("created_by_id")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("discord_aliases")
}

/**
 * Append-only record of every notification the bot sends.
 *
 * `dedupeKey` is UNIQUE and is the deduplication mechanism: the sender inserts
 * the key BEFORE dispatching and treats a unique violation as "already sent".
 * Dedup is therefore atomic in Postgres and survives restarts and multiple bot
 * instances — Redis only caches this, it is never the authority.
 */
model NotificationHistory {
  id              String         @id @default(cuid())
  discordServerId String?        @map("discord_server_id")
  discordServer   DiscordServer? @relation(fields: [discordServerId], references: [id], onDelete: Cascade)
  guildId         String?        @map("guild_id")
  guild           Guild?         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  kind            String // SPAWN_WARNING | SPAWN | KILL | CP_UPDATE | MAINTENANCE | ANNOUNCEMENT
  dedupeKey       String         @unique @map("dedupe_key")
  channelId       String?        @map("channel_id")
  messageId       String?        @map("message_id")
  status          String         @default("PENDING") // PENDING | SENT | FAILED
  error           String?
  payload         Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  sentAt          DateTime?      @map("sent_at")

  @@index([kind, createdAt])
  @@index([discordServerId, createdAt])
  @@map("notification_history")
}

/** Append-only CP change ledger — powers `!cp history` and growth stats. */
model CombatPowerHistory {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id")
  user     User        @relation("CpUpdateSubject", fields: [userId], references: [id], onDelete: Cascade)

  oldCp Int? @map("old_cp")
  newCp Int  @map("new_cp")
  // Denormalized (newCp - oldCp) so growth queries stay a plain SUM.
  delta Int?

  source         String  @default("DISCORD") // DISCORD | DISCORD_OCR | WEB | SYSTEM
  actorId        String? @map("actor_id")
  actor          User?   @relation("CpUpdateActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorDiscordId String? @map("actor_discord_id")

  // ─── OCR provenance (source = DISCORD_OCR) ───
  // Discord CDN URL; note Discord expires signed attachment URLs (~24h), so
  // this serves near-term officer review rather than permanent forensics.
  imageUrl      String? @map("image_url")
  /// Page-level OCR confidence 0..1; null for typed updates.
  ocrConfidence Float?  @map("ocr_confidence")
  /// Scan looked suspicious (implausible jump / low confidence / IGN mismatch).
  /// The update still applied — this only marks it for officer review.
  flagged       Boolean @default(false)
  flagReason    String? @map("flag_reason")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([memberId, createdAt(sort: Desc)])
  @@index([guildId, createdAt(sort: Desc)])
  @@map("combat_power_history")
}

/** Periodic guild CP aggregate written by the scheduled CP monitor. */
model GuildCpSnapshot {
  id             String   @id @default(cuid())
  guildId        String   @map("guild_id")
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  highestCp      Int?     @map("highest_cp")
  lowestCp       Int?     @map("lowest_cp")
  averageCp      Int?     @map("average_cp")
  totalCp        BigInt?  @map("total_cp")
  membersCounted Int      @default(0) @map("members_counted")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt(sort: Desc)])
  @@map("guild_cp_snapshots")
}
