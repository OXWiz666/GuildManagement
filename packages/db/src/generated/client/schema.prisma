// ─── Guild Management System — Prisma Schema ────
// Core principle: balances derived from ledger, never stored directly.
// Audit log is append-only. Roles are per-guild.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ign    String?
  cp     Int?
  class  String?
  weapon String?

  refreshTokens        RefreshToken[]
  sessions             Session[]
  guildMembers         GuildMember[]
  auditLogsAsActor     AuditLog[]            @relation("AuditActor")
  ledgerEntriesAsActor LedgerEntry[]         @relation("LedgerActor")
  passwordResetTokens  PasswordResetToken[]
  guildJoinRequests    GuildJoinRequest[]
  attendanceRecords    AttendanceRecord[]
  factionAnnouncements FactionAnnouncement[] @relation("FactionAnnouncementCreator")
  factionEvents        FactionEvent[]        @relation("FactionEventCreator")
  notifications        Notification[]
  bossRotationsUpdated BossRotation[]        @relation("BossRotationUpdater")

  @@map("users")
}

// ═══════════════════════════════════════════════════
// AUTHENTICATION
// ═══════════════════════════════════════════════════
model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @map("token_hash") // SHA-256, never raw
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId   String   @map("family_id") // Token family for rotation/replay detection
  isRevoked  Boolean  @default(false) @map("is_revoked")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Session {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  lastActive DateTime @default(now()) @map("last_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([lastActive])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════════════════
// GUILDS
// ═══════════════════════════════════════════════════
model Guild {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?  @map("avatar_url")
  bannerUrl   String?  @map("banner_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inviteCode String? @unique @map("invite_code")

  settings           GuildSettings?
  members            GuildMember[]
  ledgerEntries      LedgerEntry[]
  auditLogs          AuditLog[]
  joinRequests       GuildJoinRequest[]
  attendanceSessions AttendanceSession[]
  bossSchedules      BossSchedule[]
  bossTurnSchedules  BossSchedule[]             @relation("BossTurnGuild")
  lootSales          LootSale[]
  pointsSnapshots    GuildPointsSnapshot[]
  auctionItems       AuctionItem[]
  itemRequests       ItemRequest[]
  legendaryRequests  LegendaryPriorityRequest[]
  itemDistributions  ItemDistribution[]
  activities         GuildActivity[]

  @@map("guilds")
}

model GuildSettings {
  id      String @id @default(cuid())
  guildId String @unique @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // Currency config — never hard-coded
  currencyCode            String  @default("PHP") @map("currency_code")
  currencySymbol          String  @default("₱") @map("currency_symbol")
  secondaryCurrencyCode   String? @map("secondary_currency_code") // e.g. "DIAMOND"
  secondaryCurrencySymbol String? @map("secondary_currency_symbol") // e.g. "💎"

  // Economy settings (integer basis points / percentages)
  taxRatePercent Int @default(10) @map("tax_rate_percent")

  // Activity point values (configurable per guild)
  attendancePoints Int @default(10) @map("attendance_points")
  bossKillPoints   Int @default(50) @map("boss_kill_points")

  // Rank multipliers stored as JSON for flexibility
  // e.g. { "GUILD_LEADER": 2.0, "OFFICER": 1.5, "CORE_MEMBER": 1.2, "MEMBER": 1.0 }
  rankMultipliers Json @default("{}") @map("rank_multipliers")

  // Share distribution model
  activeShareModel String @default("EQUAL") @map("active_share_model")

  // Guild Points reset cycle — "MANUAL" | "WEEKLY" | "MONTHLY"
  pointsResetCycle String @default("MANUAL") @map("points_reset_cycle")

  // Per-rank item request limits per cycle (JSON: { "CORE_MEMBER": 7, "ELITE_MEMBER": 7, "MEMBER": 5, "OFFICER": 5 })
  itemRequestLimits Json @default("{}") @map("item_request_limits")

  // Guild Market distribution rules — CP tier thresholds + per-tier item limits + priority weights
  // Shape: { cpTiers: { eliteMinCp, upperMinCp }, limits: { CORE/ELITE/UPPER/LOWER: { logs, temporalPieces, materials } }, weights: {...} }
  marketRules Json @default("{}") @map("market_rules")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guild_settings")
}

model GuildMember {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  guildId String @map("guild_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  role       GuildRole @default(MEMBER)
  rankName   String    @default("Lower Rank") @map("rank_name")
  ign        String?   @map("ign") // In-Game Name
  cp         Int?      @map("cp") // Combat Power
  class      String?   @map("class") // Character class (e.g. Warrior, Mage)
  weapon     String?   @map("weapon") // Equipped weapon
  memberCode String?   @unique @map("member_code") // Unique member identifier
  joinedAt   DateTime  @default(now()) @map("joined_at")
  isActive   Boolean   @default(true) @map("is_active")

  // Bid points — separate from DKP/ledger balance, earned from same activities
  // Spending on auctions does NOT reduce DKP ranking score
  bidPoints          Int       @default(0) @map("bid_points")
  bidPointsLastReset DateTime? @map("bid_points_last_reset")

  // Guild Market: officer manual priority-sequence override (audited)
  marketPrioritySeq    Int?    @map("market_priority_seq")
  marketPriorityReason String? @map("market_priority_reason")

  // Guild Market: member's chosen/wanted items (array of slot keys) shown to officers
  marketWishlist Json @default("[]") @map("market_wishlist")

  auctionBids       AuctionBid[]
  itemRequests      ItemRequest[]
  legendaryRequests LegendaryPriorityRequest[]
  itemDistributions ItemDistribution[]
  equipment         MemberEquipment[]

  @@unique([userId, guildId])
  @@index([guildId])
  @@index([userId])
  @@map("guild_members")
}

enum GuildRole {
  ADMIN
  FACTION_LEADER
  GUILD_LEADER
  OFFICER
  CORE_MEMBER
  ELITE_MEMBER
  MEMBER
}

// ═══════════════════════════════════════════════════
// GUILD POINTS RESET SNAPSHOTS
// Immutable record of each member's points before each reset
// ═══════════════════════════════════════════════════
model GuildPointsSnapshot {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // Who triggered the reset
  actorId      String   @map("actor_id")
  resetCycle   String   @map("reset_cycle") // "WEEKLY" | "MONTHLY" | "MANUAL"
  snapshotData Json     @map("snapshot_data") // Array of { memberId, userId, ign, dkp, bidPoints }
  membersCount Int      @map("members_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([guildId])
  @@index([createdAt])
  @@map("guild_points_snapshots")
}

// ═══════════════════════════════════════════════════
// AUCTIONS
// Leaders create auction items; members bid with bid points
// ═══════════════════════════════════════════════════
model AuctionItem {
  id        String @id @default(cuid())
  guildId   String @map("guild_id")
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  creatorId String @map("creator_id")

  itemName    String        @map("item_name")
  description String?
  imageUrl    String?       @map("image_url")
  category    String        @default("OTHER") // "WEAPON" | "ARMOR" | etc.
  startingBid Int           @default(0) @map("starting_bid") // in bid points
  currentBid  Int           @default(0) @map("current_bid")
  winnerId    String?       @map("winner_id") // GuildMember.id of winner
  status      AuctionStatus @default(ACTIVE)
  endsAt      DateTime      @map("ends_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  bids AuctionBid[]

  @@index([guildId, status])
  @@index([endsAt])
  @@index([guildId, status, winnerId, endsAt])
  @@map("auction_items")
}

model AuctionBid {
  id        String      @id @default(cuid())
  auctionId String      @map("auction_id")
  auction   AuctionItem @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  memberId  String      @map("member_id")
  member    GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  bidAmount Int         @map("bid_amount") // in bid points
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([auctionId])
  @@index([memberId])
  @@map("auction_bids")
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

// ═══════════════════════════════════════════════════
// ITEM REQUESTS & WITHDRAWAL REQUESTS
// Members request items or currency withdrawals;
// leaders approve/decline/fulfill
// ═══════════════════════════════════════════════════
model ItemRequest {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type   ItemRequestType // ITEM | WITHDRAWAL
  status ItemRequestStatus @default(PENDING)

  // For ITEM requests
  itemName     String? @map("item_name")
  quantity     Int?    @default(1)
  itemCategory String? @map("item_category") // matches CATEGORIES list

  // For WITHDRAWAL requests
  withdrawalAmount   Decimal? @map("withdrawal_amount") @db.Decimal(12, 2)
  withdrawalCurrency String?  @map("withdrawal_currency") // "PHP" | "DIAMOND"

  note         String? // Applicant's note
  reviewNote   String?   @map("review_note") // Leader/officer's response note
  reviewedById String?   @map("reviewed_by_id") // Actor who reviewed
  reviewedAt   DateTime? @map("reviewed_at")
  fulfilledAt  DateTime? @map("fulfilled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@index([memberId])
  @@index([guildId, type, status, updatedAt])
  @@index([guildId, memberId, type, status, updatedAt])
  @@map("item_requests")
}

enum ItemRequestType {
  ITEM
  WITHDRAWAL
}

enum ItemRequestStatus {
  PENDING
  APPROVED
  DECLINED
  FULFILLED
}

// ═══════════════════════════════════════════════════
// GUILD MARKET — LEGENDARY PRIORITY REQUESTS
// Members request priority for legendary-tier rewards;
// officers review, assign a priority sequence, and complete.
// ═══════════════════════════════════════════════════
model LegendaryPriorityRequest {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // WEAPON | LEGEND_ACCESSORIES | LEGEND_CLOAK | ABILITY_REROLL | ABILITY_PASSIVE
  category    String
  currentGear String? @map("current_gear") // Current gear status / context
  reason      String? // Reason for priority
  prioritySeq Int?    @map("priority_seq") // Officer-assigned sequence

  // PENDING | APPROVED | REJECTED | COMPLETED
  status       String    @default("PENDING")
  officerNote  String?   @map("officer_note")
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  completedAt  DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([guildId, status])
  @@index([memberId])
  @@map("legendary_priority_requests")
}

// ═══════════════════════════════════════════════════
// GUILD MARKET — ITEM DISTRIBUTIONS
// Officer-recorded distribution events. Wide per-slot gear
// data is stored as JSON (`items`) for future expansion.
// ═══════════════════════════════════════════════════
model ItemDistribution {
  id       String      @id @default(cuid())
  guildId  String      @map("guild_id")
  guild    Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  formType String  @map("form_type") // CORE | NON_CORE
  rankTier String? @map("rank_tier") // CORE | ELITE | UPPER | LOWER

  // Snapshots captured at distribution time (members change over time)
  ignSnapshot    String? @map("ign_snapshot")
  classSnapshot  String? @map("class_snapshot")
  cpSnapshot     Int?    @map("cp_snapshot")
  pointsSnapshot Int?    @map("points_snapshot")
  prioritySeq    Int?    @map("priority_seq")

  // { weapon: 1, headpiece: 1, logs: 5, temporalPieces: 3, materials: 2, ... }
  items Json    @default("{}")
  note  String?

  distributedById String   @map("distributed_by_id")
  overridden      Boolean  @default(false) // Rank limit override used
  overrideReason  String?  @map("override_reason")
  distributedAt   DateTime @default(now()) @map("distributed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([guildId, distributedAt])
  @@index([memberId])
  @@map("item_distributions")
}

// ═══════════════════════════════════════════════════
// MEMBER EQUIPMENT — Item Screenshot Update feature
// Per-slot gear detected from an uploaded equipment screenshot
// (OCR in the browser) and matched to existing Supabase icon objects.
// One current item per slot (upsert on re-scan). We only ever REFERENCE
// existing icon storage paths here — never write to the icon buckets.
// ═══════════════════════════════════════════════════
model MemberEquipment {
  id       String      @id @default(cuid())
  memberId String      @map("member_id")
  member   GuildMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  slotType String @map("slot_type") // one of EQUIPMENT_SLOTS keys (weapon, helm, ...)
  itemName String @map("item_name")

  // Storage PATH (bucket-relative object key), signed on read — never a raw public URL
  iconUrl    String  @map("icon_url")
  iconBucket String  @map("icon_bucket")
  rarity     String?

  confidence  Float   @default(0)
  needsReview Boolean @default(false) @map("needs_review")

  // Storage path of the uploaded source screenshot (EquipmentScreenshots bucket)
  sourceScreenshotUrl String? @map("source_screenshot_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([memberId, slotType])
  @@index([memberId])
  @@map("member_equipment")
}

// ═══════════════════════════════════════════════════
// IMMUTABLE LEDGER
// Balances are ALWAYS derived by summing entries.
// Entries are NEVER updated or deleted.
// ═══════════════════════════════════════════════════
model LedgerEntry {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  guild   Guild  @relation(fields: [guildId], references: [id])

  // Who is affected
  accountType AccountType @map("account_type")
  accountId   String      @map("account_id") // userId or guildId

  // What changed — integer units (cents), never float
  currency  String
  amount    BigInt // Stored as integer cents/smallest unit
  entryType LedgerEntryType @map("entry_type")

  // Why — links to the source event
  referenceType String @map("reference_type") // "BOSS_KILL", "SALE", "PAYOUT", etc.
  referenceId   String @map("reference_id")

  // Idempotency — prevents double-crediting on retries
  idempotencyKey String @unique @map("idempotency_key")

  // Who initiated it
  actorId String @map("actor_id")
  actor   User   @relation("LedgerActor", fields: [actorId], references: [id])

  description String?
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([accountType, accountId, currency])
  @@index([guildId])
  @@index([guildId, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([guildId, accountType, entryType, currency])
  @@index([guildId, accountType, currency, createdAt])
  @@index([guildId, accountId, accountType, referenceType])
  @@index([guildId, accountId, accountType, entryType, currency])
  @@map("ledger_entries")
}

enum AccountType {
  MEMBER
  GUILD_FUND
  TAX
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

// ═══════════════════════════════════════════════════
// AUDIT LOG — append-only, every significant action
// ═══════════════════════════════════════════════════
model AuditLog {
  id String @id @default(cuid())

  // Who performed the action
  actorId String @map("actor_id")
  actor   User   @relation("AuditActor", fields: [actorId], references: [id])

  // Where (optional — some actions are system-wide)
  guildId String? @map("guild_id")
  guild   Guild?  @relation(fields: [guildId], references: [id])

  // What happened
  action   String // "USER_LOGIN", "MEMBER_PROMOTED", etc.
  target   String? // Target entity type
  targetId String? @map("target_id")

  // Details — before/after state, extra context
  detail    Json?
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([guildId])
  @@index([action])
  @@index([createdAt])
  @@index([guildId, action, createdAt])
  @@map("audit_logs")
}

model FactionAnnouncement {
  id        String   @id @default(cuid())
  title     String
  body      String
  priority  String   @default("NORMAL")
  status    String   @default("ACTIVE")
  creatorId String   @map("creator_id")
  creator   User     @relation("FactionAnnouncementCreator", fields: [creatorId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("faction_announcements")
}

model FactionEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  location    String?
  status      String    @default("ACTIVE")
  creatorId   String    @map("creator_id")
  creator     User      @relation("FactionEventCreator", fields: [creatorId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([startsAt])
  @@map("faction_events")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  metadata  Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model GuildJoinRequest {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  userId  String @map("user_id")
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ign    String            @map("ign")
  cp     Int               @map("cp")
  class  String            @map("class")
  weapon String            @map("weapon")
  status JoinRequestStatus @default(PENDING)

  // Equipment captured at apply time (Item Screenshot Update). Array of
  // { slotType, itemName, iconPath, iconBucket, rarity?, confidence }. Shown to
  // the reviewing leader and materialised into MemberEquipment on acceptance.
  gearItems Json? @map("gear_items")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, guildId])
  @@index([guildId])
  @@index([userId])
  @@map("guild_join_requests")
}

enum AttendanceType {
  GUILD
  FACTION
}

enum AttendanceRecordStatus {
  PENDING
  CONFIRMED
}

enum BossEventStatus {
  UPCOMING
  SPAWNED
  KILLED
}

model AttendanceSession {
  id             String             @id @default(cuid())
  guildId        String             @map("guild_id")
  guild          Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  code           String             @unique
  type           AttendanceType     @default(GUILD)
  title          String
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")
  expiresAt      DateTime           @map("expires_at")
  records        AttendanceRecord[]
  bossScheduleId String?            @map("boss_schedule_id")
  bossSchedule   BossSchedule?      @relation(fields: [bossScheduleId], references: [id], onDelete: SetNull)

  @@index([guildId])
  @@index([guildId, createdAt])
  @@index([guildId, expiresAt])
  @@index([bossScheduleId])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String                 @id @default(cuid())
  sessionId String                 @map("session_id")
  userId    String                 @map("user_id")
  session   AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    AttendanceRecordStatus @default(PENDING)
  joinedAt  DateTime               @default(now()) @map("joined_at")

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@index([userId])
  // Officer "pending verification" queue filters by session + status.
  @@index([sessionId, status])
  @@map("attendance_records")
}

model BossSchedule {
  id                 String              @id @default(cuid())
  guildId            String?             @map("guild_id") // Null means Faction unified schedule
  guild              Guild?              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  bossName           String              @map("boss_name")
  bossImageUrl       String?             @map("boss_image_url")
  spawnTime          DateTime            @map("spawn_time")
  location           String
  guildTurn          String?             @map("guild_turn")
  guildTurnGuildId   String?             @map("guild_turn_guild_id")
  guildTurnGuild     Guild?              @relation("BossTurnGuild", fields: [guildTurnGuildId], references: [id], onDelete: SetNull)
  status             BossEventStatus     @default(UPCOMING)
  killedAt           DateTime?           @map("killed_at")
  creatorId          String              @map("creator_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  attendanceSessions AttendanceSession[]

  lootDrop      String?    @map("loot_drop")
  screenshotUrl String?    @map("screenshot_url")
  lootSales     LootSale[]

  @@index([guildId])
  @@index([guildTurnGuildId])
  @@index([spawnTime])
  @@index([status])
  @@index([guildId, status, killedAt])
  @@index([bossName, status, spawnTime])
  @@index([bossName, status, killedAt])
  @@map("boss_schedules")
}

model BossRotation {
  id                     String    @id @default(cuid())
  bossName               String    @unique @map("boss_name")
  queueGuildIds          Json      @map("queue_guild_ids")
  currentIndex           Int       @default(0) @map("current_index")
  nextSpawnTime          DateTime? @map("next_spawn_time")
  // When true, queueGuildIds is the faction leader's explicit master-list of
  // participating guilds for this boss and is honored as-is (guilds NOT listed
  // are excluded). When false, the queue defaults to all active faction guilds.
  participantsConfigured Boolean   @default(false) @map("participants_configured")
  updatedById            String?   @map("updated_by_id")
  updatedBy              User?     @relation("BossRotationUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([bossName])
  @@map("boss_rotations")
}

/**
 * Day-based low-boss rotation (faction-leader owned). A single-row config for the
 * faction: the guild assigned to a day takes ALL flagged "low" bosses that day.
 * - mode:         WEEKLY (weekday→guild, repeats) or MONTHLY (calendar date→guild)
 * - lowBossNames: which registry bosses follow this day rotation (JSON string[])
 * - weekly:       { "0".."6" (Sun..Sat) → guildId } (JSON)
 * - days:         { "YYYY-MM-DD" → guildId } (JSON)
 */
model BossLowRotation {
  id           String   @id @default("singleton")
  mode         String   @default("MONTHLY")
  lowBossNames Json     @default("[]") @map("low_boss_names")
  weekly       Json     @default("{}")
  days         Json     @default("{}")
  updatedById  String?  @map("updated_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("boss_low_rotations")
}

/**
 * Unified guild activity scheduler: Guild Boss, Guild War, and PK War events.
 * A simple calendar entry with optional opponent, result, and member attendance.
 */
model GuildActivity {
  id           String                  @id @default(cuid())
  guildId      String                  @map("guild_id")
  guild        Guild                   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type         String // GUILD_BOSS | GUILD_WAR | PK_WAR
  title        String
  location     String?
  opponent     String? // enemy / rival guild
  notes        String?
  scheduledAt  DateTime                @map("scheduled_at")
  status       String                  @default("UPCOMING") // UPCOMING | COMPLETED | CANCELLED
  result       String? // WIN | LOSS | DRAW
  scoreFor     Int?                    @map("score_for")
  scoreAgainst Int?                    @map("score_against")
  creatorId    String                  @map("creator_id")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  attendees    GuildActivityAttendee[]

  @@index([guildId, scheduledAt])
  @@index([guildId, type, status])
  @@map("guild_activities")
}

model GuildActivityAttendee {
  id         String        @id @default(cuid())
  activityId String        @map("activity_id")
  activity   GuildActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String        @map("user_id")
  status     String        @default("PENDING") // PENDING | CONFIRMED
  joinedAt   DateTime      @default(now()) @map("joined_at")

  @@unique([activityId, userId])
  @@index([activityId])
  @@map("guild_activity_attendees")
}

model Boss {
  id            String   @id @default(cuid())
  name          String   @unique
  level         Int
  type          String // "LONG_CYCLE" | "FIXED_SCHEDULE"
  cooldownHours Int?     @map("cooldown_hours")
  location      String
  fixedSpawns   Json?    @map("fixed_spawns")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("bosses")
}

model LootSale {
  id                String        @id @default(cuid())
  guildId           String        @map("guild_id")
  guild             Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  bossScheduleId    String?       @map("boss_schedule_id")
  bossSchedule      BossSchedule? @relation(fields: [bossScheduleId], references: [id], onDelete: SetNull)
  itemName          String        @map("item_name")
  category          String // e.g. "WEAPON", "ARMOR", "ACCESSORY", "MATERIAL", "SCROLL", "OTHER"
  saleValue         BigInt        @map("sale_value") // Integer cents
  taxRatePercent    Int           @map("tax_rate_percent")
  taxAmount         BigInt        @map("tax_amount") // Integer cents
  netProfit         BigInt        @map("net_profit") // Integer cents
  distributionModel String        @map("distribution_model") // "PRO_RATA", "EQUAL", "DKP"
  currency          String        @default("PHP")
  creatorId         String        @map("creator_id")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([guildId])
  @@index([bossScheduleId])
  // Sold-item log is read newest-first per guild.
  @@index([guildId, createdAt])
  @@map("loot_sales")
}
