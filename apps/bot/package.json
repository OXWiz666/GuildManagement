{
  "name": "@guild/bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf node_modules .turbo dist"
  },
  "dependencies": {
    "@guild/core": "workspace:*",
    "@guild/db": "workspace:*",
    "@guild/shared": "workspace:*",
    "@supabase/supabase-js": "^2.106.1",
    "discord.js": "^14.16.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
